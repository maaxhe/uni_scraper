# Stud.IP Dashboard – Configuration
# Copy this file as ".env" and fill in your values.
# Guide: see README.md

# Your university login (student ID or short username)
STUDIP_USERNAME=your_username

# Your university password
# Special characters? Wrap in quotes: STUDIP_PASSWORD="Pa$$word!"
STUDIP_PASSWORD=your_password

# ── AI key for summaries and chat (at least one required for AI features) ──

# Option A: Anthropic (Claude) — https://console.anthropic.com → "API Keys"
ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI (GPT) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Option C: Any OpenAI-compatible provider (Groq, Mistral, Ollama, …)
# OPENAI_API_KEY=your_key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# ── Model overrides (optional) ──
# ANTHROPIC_MODEL=claude-opus-4-6
# OPENAI_MODEL=gpt-4o-mini

# Folder where course files will be saved — must already exist!
# Mac example:     COURSES_DIR=/Users/yourname/Documents/Uni/Courses
# Windows example: COURSES_DIR=C:/Users/yourname/Documents/Uni/Courses
COURSES_DIR=/path/to/your/courses
