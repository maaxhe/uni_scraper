# Stud.IP Dashboard – Konfiguration
# Kopiere diese Datei als ".env" und fülle die Werte aus.
# Anleitung: siehe README.md

# Dein Uni-Login (Benutzername / Matrikelnummer)
STUDIP_USERNAME=dein_benutzername

# Dein Uni-Passwort
# Sonderzeichen? In Anführungszeichen: STUDIP_PASSWORD="Pa$$wort!"
STUDIP_PASSWORD=dein_passwort

# Anthropic API-Key für KI-Zusammenfassungen und Chat
# Kostenlos holen: https://console.anthropic.com → "API Keys" → "Create Key"
# Ohne diesen Key funktionieren Datei-Sync und Dashboard trotzdem.
ANTHROPIC_API_KEY=sk-ant-...

# Ordner, in dem Kursdateien gespeichert werden (muss existieren!)
# Mac-Beispiel:    COURSES_DIR=/Users/deinname/Dokumente/Uni/Kurse
# Windows-Beispiel: COURSES_DIR=C:/Users/deinname/Dokumente/Uni/Kurse
COURSES_DIR=/pfad/zu/deinen/kursen
